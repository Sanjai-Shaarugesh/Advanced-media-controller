msgid "Advanced Media Controller"
msgstr "高级媒体控制器"

msgid "General"
msgstr "常规"

msgid "Panel Placement"
msgstr "面板位置"

msgid "Where the indicator sits in the top bar"
msgstr "指示器在顶部栏中的位置"

msgid "Panel Position"
msgstr "面板位置"

msgid "Left"
msgstr "左"

msgid "Center"
msgstr "中"

msgid "Right"
msgstr "右"

msgid "Panel Index"
msgstr "面板索引"

msgid "Position within the panel area (-1 = automatic)"
msgstr "面板区域内的位置（-1 = 自动）"

msgid "Panel Label"
msgstr "面板标签"

msgid "Track name shown in the top bar"
msgstr "顶部栏中显示的曲目名称"

msgid "Show Track Name"
msgstr "显示曲目名称"

msgid "Display the current track title in the panel"
msgstr "在面板中显示当前曲目标题"

msgid "Show Artist Name"
msgstr "显示艺术家名称"

msgid "Append the artist name to the track title"
msgstr "将艺术家名称附加到曲目标题"

msgid "Title / Artist Separator"
msgstr "标题 / 艺术家分隔符"

msgid "Panel Scrolling"
msgstr "面板滚动"

msgid "Marquee scroll of the track label in the top bar"
msgstr "顶部栏曲目标签的跑马灯滚动"

msgid "Enable Panel Label Scrolling"
msgstr "启用面板标签滚动"

msgid "Scroll the track/artist text one full loop then pause before repeating. When off, the text is truncated with an ellipsis."
msgstr "将曲目/艺术家文字滚动一个完整循环后暂停，然后重复。关闭时，文字以「…」截断。"

msgid "Panel Scroll Speed"
msgstr "面板滚动速度"

msgid "1 = slowest, 10 = fastest"
msgstr "1 = 最慢，10 = 最快"

msgid "Popup Player"
msgstr "弹出播放器"

msgid "Title Scrolling"
msgstr "标题滚动"

msgid "Marquee behaviour for the track title inside the popup"
msgstr "弹出窗口中曲目标题的跑马灯行为"

msgid "Enable Title Scrolling"
msgstr "启用标题滚动"

msgid "Scroll long track titles from start to end, pause, then repeat. When off, the text is truncated with an ellipsis."
msgstr "将长标题从头到尾滚动，暂停后重复。关闭时，文字以「…」截断。"

msgid "Title Scroll Speed"
msgstr "标题滚动速度"

msgid "Artist Scrolling"
msgstr "艺术家滚动"

msgid "Marquee behaviour for the artist name inside the popup"
msgstr "弹出窗口中艺术家名称的跑马灯行为"

msgid "Enable Artist Scrolling"
msgstr "启用艺术家滚动"

msgid "Scroll long artist names from start to end, pause, then repeat. When off, the text is truncated with an ellipsis."
msgstr "将长艺术家名称从头到尾滚动，暂停后重复。"

msgid "Artist Scroll Speed"
msgstr "艺术家滚动速度"

msgid "Album Art"
msgstr "专辑封面"

msgid "Vinyl-record rotation animation"
msgstr "黑胶唱片旋转动画"

msgid "Enable Vinyl Record Rotation (Global Default)"
msgstr "启用黑胶唱片旋转（全局默认）"

msgid "Global default when no per-app setting exists. Per-app overrides in the ‘Vinyl Apps’ section take priority."
msgstr "当没有每个应用设置时的全局默认値。「黑胶应用」部分中的每个应用覆盖优先。"

msgid "Rotation Speed (seconds per revolution)"
msgstr "旋转速度（每圈秒数）"

msgid "5 = fastest, 60 = slowest. Recommended: 20–30"
msgstr "5 = 最快，60 = 最慢。建议：20–30"

msgid "Vinyl Effect Details"
msgstr "黑胶效果详情"

msgid "How the animated vinyl record works"
msgstr "动态黑胶唱片的工作原理"

msgid "- Album cover appears on a spinning vinyl disc\n"
"- Black vinyl grooves are visible around the edges\n"
"- Animated tonearm moves in and out with playback state\n"
"- Rotation pauses smoothly when music pauses\n"
"  (disc angle is preserved and resumes from the same position)\n"
"- Disc resets to 0° only on a genuine Stop\n"
"- Double-click album art to toggle vinyl for THAT player’s app only\n"
"- Per-app settings override the global default above\n"
"- All seen apps are stored; re-enable any time from Vinyl Apps page"
msgstr "- 专辑封面显示在旋转的黑胶唱片上\n"
"- 黑胶沟纹在边缘可见\n"
"- 动态唱臂随播放状态移动\n"
"- 音乐暂停时旋转平滑停止\n"
"  （圆盘角度被保留，从相同位置继续）\n"
"- 圆盘仅在真正停止时重置为0°\n"
"- 双击专辑封面可切换该播放器应用的黑胶\n"
"- 每个应用设置覆盖全局默认\n"
"- 所有已见应用均已存储；随时从黑胶应用页面重新启用"

msgid "Vinyl Apps"
msgstr "黑胶应用"

msgid "How to Enable Vinyl Style for an App"
msgstr "如何为应用启用黑胶样式"

msgid "Start playing music"
msgstr "开始播放音乐"

msgid "Open any media player or browser web app (YouTube, Spotify Web, SoundCloud, etc.) and play a track so it appears as a media source."
msgstr "打开任意媒体播放器或浏览器网页应用（YouTube、Spotify Web、SoundCloud等），播放曲目使其显示为媒体源。"

msgid "Open the extension popup"
msgstr "打开扩展弹出窗口"

msgid "Click the media controller in the top panel to open the popup player."
msgstr "点击顶部面板中的媒体控制器以打开弹出播放器。"

msgid "Double-click the album art"
msgstr "双击专辑封面"

msgid "Double-click the album art image in the popup to toggle the vinyl record style for that specific app instance. The instance is saved here automatically."
msgstr "双击弹出窗口中的专辑封面图片，以切换该特定应用实例的黑胶样式。实例将自动保存。"

msgid "Manage saved instances below"
msgstr "在下方管理已保存的实例"

msgid "All stored instances appear in the section below with their app icon and name. Toggle them on/off or remove them at any time."
msgstr "所有已存储的实例带应用图标和名称显示在下方部分。随时切换开关/关闭或删除。"

msgid "Saved App Instances"
msgstr "已保存的应用实例"

msgid "Instances stored by double-clicking the album art in the popup. Icons are loaded from the system .desktop database. Toggle the vinyl effect on/off or remove any entry."
msgstr "通过双击封面保存的实例。图标从系统.desktop数据库加载。"

msgid "No instances saved yet"
msgstr "尚未保存任何实例"

msgid "Double-click the album art in the popup while music is playing to save an instance here."
msgstr "播放音乐时双击弹出窗口中的专辑封面，将实例保存到这里。"

msgid "Add an App Manually"
msgstr "手动添加应用"

msgid "Search installed apps — including browsers — to manually add a vinyl entry. Useful for browser web apps whose instance hasn’t been captured yet via double-click."
msgstr "搜索已安装的应用（包括浏览器）以手动添加黑胶条目。"

msgid "Browser web apps (YouTube, Spotify Web, etc.)"
msgstr "浏览器网页应用（YouTube、Spotify Web等）"

msgid "For web apps, add the browser itself (e.g. Google Chrome, Firefox). Then double-click the album art when that browser is playing music — the extension will capture the exact instance automatically."
msgstr "对于网页应用，请添加浏览器本身（如 Google Chrome、Firefox）。然后在该浏览器播放音乐时双击专辑封面，扩展将自动捕获确切的实例。"

msgid "Search apps"
msgstr "搜索应用"

msgid "Type an app or browser name…"
msgstr "输入应用或浏览器名称…"

msgid "Saved Instances"
msgstr "已保存的实例"

msgid "Other Apps"
msgstr "其他应用"

msgid "No matching apps found"
msgstr "未找到匹配的应用"

msgid "renamed from"
msgstr "重命名自"

msgid "Rename “%s”"
msgstr "重命名“%s”"

msgid "Remove %s from saved instances"
msgstr "从已保存实例中删除%s"

msgid "Rename Instance"
msgstr "重命名实例"

msgid "Enter a custom display name for “%s”.\n"
"Leave blank to reset to the default name."
msgstr "输入“%s”的自定义显示名称。\n"
"留空以重置为默认名称。"

msgid "Cancel"
msgstr "取消"

msgid "Rename"
msgstr "重命名"

msgid "Display name"
msgstr "显示名称"

msgid "About"
msgstr "关于"

msgid "Beautiful and modern media controls with multi-instance support"
msgstr "支持多实例的美观现代媒体控制"

msgid "Version 1.0"
msgstr "版本 1.0"

msgid "Modern media controls with native GNOME design"
msgstr "采用原生GNOME设计的现代媒体控制"

msgid "Extension Links"
msgstr "扩展链接"

msgid "Source code, issues, and contributions"
msgstr "源代码、问题和贡献"

msgid "View on GitHub"
msgstr "在GitHub上查看"

msgid "☕ Support by buying me a coffee – just scan the QR code!"
msgstr "☕ 请我嗝杯咋啊来支持 – 扫描二维码即可！"

msgid "Preferred Method - Scan QR code to support development"
msgstr "推荐方式 – 扫描二维码支持开发"

msgid "Donation Address"
msgstr "捐赠地址"

msgid "Donation address"
msgstr "捐赠地址"

msgid "☕ Buy Me a Coffee"
msgstr "☕ 请我喝咋啊"

msgid "Support development with a small donation"
msgstr "小额捐赠支持开发"

msgid "License & Credits"
msgstr "许可证与致谢"

msgid "Open source software information"
msgstr "开源软件信息"

msgid "Open Source License"
msgstr "开源许可证"

msgid "GPL-3.0 License - Free and open source software"
msgstr "GPL-3.0许可证 – 自由开源软件"

msgid "Media Data Sources"
msgstr "媒体数据源"

msgid "MPRIS D-Bus interface - Standard media player remote interfacing"
msgstr "MPRIS D-Bus接口 – 标准媒体播放器远程接口"

msgid "Key Features"
msgstr "主要功能"

msgid "• Multi-instance browser support\n"
"• Per-app rotating vinyl record album art\n"
"• Animated tonearm\n"
"• Smooth animations\n"
"• Double-click to toggle vinyl per app\n"
"• All seen apps remembered — re-enable any time"
msgstr "• 多实例浏览器支持\n"
"• 每个应用的旋转黑胶专辑封面\n"
"• 动态唱臂\n"
"• 流畅动画\n"
"• 双击可切换每个应用的黑胶\n"
"• 所有已见应用均被记住 — 随时重新启用"

msgid "Copy to Clipboard"
msgstr "复制到剪贴板"

msgid "Unable to copy automatically. Select the address below and press Ctrl+C:"
msgstr "无法自动复制。请选择下方地址并按Ctrl+C："

msgid "Close"
msgstr "关闭"

msgid "Media Controls"
msgstr "媒体控制"

msgid "Panel Settings"
msgstr "面板设置"

msgid "Configure the position and appearance in the top panel"
msgstr "配置顶部面板中的位置和外观"

msgid "Display Settings"
msgstr "显示设置"

msgid "Configure what appears in the panel"
msgstr "配置面板中显示的内容"

msgid "Display track information in the panel"
msgstr "在面板中显示曲目信息"

msgid "Include artist name with track title"
msgstr "在曲目标题中包含艺术家名称"

msgid "Maximum Title Length"
msgstr "最大标题长度"

msgid "Characters to display before scrolling starts"
msgstr "滚动开始前显示的字符数"

msgid "Scroll Speed"
msgstr "滚动速度"

msgid "Separator Text"
msgstr "分隔符文本"

