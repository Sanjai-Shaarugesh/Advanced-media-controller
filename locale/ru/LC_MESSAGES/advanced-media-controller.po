msgid "Panel Placement"
msgstr "Расположение на панели"

#: prefs.js:104
msgid "Where the indicator sits in the top bar"
msgstr "Где находится индикатор на верхней панели"

#: prefs.js:108
msgid "Panel Position"
msgstr "Позиция на панели"

#: prefs.js:110
