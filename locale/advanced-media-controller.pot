#: prefs.js:1084
msgid "Data Source"
msgstr "資料來源"

#: prefs.js:1085
msgid "Where lyrics come from"
msgstr "歌詞來自何處"

#: prefs.js:1090
msgid "lrclib.net"
msgstr "lrclib.net"

#: prefs.js:1092
msgid ""
"Free, open-source time-synced lyrics database — no sign-up, no tracking, no "
