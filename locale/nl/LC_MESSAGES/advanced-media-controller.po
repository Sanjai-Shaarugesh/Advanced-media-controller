#: prefs.js:1049
msgid "Single click"
msgstr "Enkele klik"

#: prefs.js:1051
msgid ""
"When lyrics are showing: closes the lyrics panel and returns to the album art"
msgstr "Bij weergegeven songteksten: paneel sluiten en terugkeren naar albumhoes"

#: prefs.js:1056
