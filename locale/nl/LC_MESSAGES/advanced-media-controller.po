#: ui/popupPage.js
msgid "Tonearm Angles"
msgstr "Toonarmhoeken"

#: ui/popupPage.js
msgid "Control how far the animated tonearm swings when playing or at rest"
msgstr "Bepaalt hoe ver de geanimeerde toonarm swingt bij afspelen of in rust"

#: ui/popupPage.js
msgid "Parked (resting) angle"
msgstr "Rusthoek"

#: ui/popupPage.js
msgid "Degrees from vertical when music is paused or stopped. Higher moves the arm further from the disc (10 – 60°)"
msgstr "Graden van verticaal wanneer muziek gepauzeerd of gestopt is. Hoger beweegt de arm verder van de plaat (10 – 60°)"

#: ui/popupPage.js
msgid "Playing angle"
msgstr "Afspeelhoek"

#: ui/popupPage.js
msgid "Degrees from vertical when the stylus rests on the groove. Lower brings the arm closer to the disc centre (0 – 30°)"
msgstr "Graden van verticaal wanneer de naald in de groef rust. Lager brengt de arm dichter bij het midden (0 – 30°)"

#: ui/popupPage.js
msgid "Tip: parked angle must be greater than playing angle"
msgstr "Tip: rusthoek moet groter zijn dan afspeelhoek"

#: ui/popupPage.js
msgid "E.g. parked = 25°, playing = 8°. If they are equal or reversed the arm will animate incorrectly."
msgstr "Bijv.: rust = 25°, afspelen = 8°. Bij gelijkheid of omgekeerde volgorde animeert de arm onjuist."

