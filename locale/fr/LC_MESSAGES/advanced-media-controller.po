msgstr "Contrôles multimédia"

#. ── New strings added in v5.3+ ─────────────────────────────────────────────

#: ui/generalPage.js
msgid "Panel Label Width"
msgstr "Largeur de l'étiquette du panneau"

#: ui/generalPage.js
msgid "Visible pixel width of the track label in the top bar (60 – 400 px)"
msgstr "Largeur en pixels de l'étiquette de piste dans la barre supérieure (60 – 400 px)"

#: ui/popupPage.js
msgid "Popup Size"
msgstr "Taille du popup"

#: ui/popupPage.js
msgid "Width of the popup media player panel (height scales with album art)"
msgstr "Largeur du panneau du lecteur contextuel (la hauteur s'adapte à la pochette)"

#: ui/popupPage.js
msgid "Popup Width"
msgstr "Largeur du popup"

#: ui/popupPage.js
msgid "Width in pixels — album art, labels and lyrics panel all scale with this value (280 – 600 px)"
msgstr "Largeur en pixels — pochette, étiquettes et panneau de paroles s'adaptent à cette valeur (280 – 600 px)"

#: ui/popupPage.js
msgid "Tonearm Angles"
msgstr "Angles du bras de lecture"

#: ui/popupPage.js
msgid "Control how far the animated tonearm swings when playing or at rest"
msgstr "Contrôle l'amplitude du bras de lecture animé en lecture ou au repos"

#: ui/popupPage.js
msgid "Parked (resting) angle"
msgstr "Angle au repos"

#: ui/popupPage.js
msgid "Degrees from vertical when music is paused or stopped. Higher moves the arm further from the disc (10 – 60°)"
msgstr "Degrés depuis la verticale quand la musique est en pause ou arrêtée. Plus élevé éloigne le bras du disque (10 – 60°)"

#: ui/popupPage.js
msgid "Playing angle"
msgstr "Angle de lecture"

#: ui/popupPage.js
msgid "Degrees from vertical when the stylus rests on the groove. Lower brings the arm closer to the disc centre (0 – 30°)"
msgstr "Degrés depuis la verticale quand la pointe est sur le sillon. Plus bas rapproche le bras du centre (0 – 30°)"

#: ui/popupPage.js
msgid "Tip: parked angle must be greater than playing angle"
msgstr "Conseil : l'angle au repos doit être supérieur à l'angle de lecture"

#: ui/popupPage.js
msgid "E.g. parked = 25°, playing = 8°. If they are equal or reversed the arm will animate incorrectly."
msgstr "Ex. repos = 25°, lecture = 8°. Si égaux ou inversés, le bras s'animera incorrectement."

#: ui/aboutPage.js
msgid "Report a Bug"
msgstr "Signaler un bogue"

#: ui/aboutPage.js
msgid "Request a Feature"
msgstr "Demander une fonctionnalité"

#: ui/aboutPage.js
msgid "Star on GitHub"
msgstr "Étoiler sur GitHub"

#. ── New strings added in v5.4 (uploaded JS files) ─────────────────────────

msgid "%d clicks"
msgstr "%d clics"

msgid "%d times"
msgstr "%d fois"

msgid "1 click"
msgstr "1 clic"

msgid "once"
msgstr "une fois"

msgid "twice"
msgstr "deux fois"

msgid "%s — toggle lyrics"
msgstr "%s — afficher/masquer les paroles"

msgid "%s — toggle vinyl effect"
msgstr "%s — basculer l'effet vinyle"

msgid "Click the album art %s to show lyrics"
msgstr "Cliquer %s sur la pochette pour afficher les paroles"

msgid "Click again to re-open"
msgstr "Cliquer à nouveau pour rouvrir"

msgid "Album Art Click Thresholds"
msgstr "Seuils de clic sur la pochette"

msgid "Set how many rapid clicks trigger each album art action"
msgstr "Définit le nombre de clics rapides pour déclencher chaque action sur la pochette"

msgid "Clicks to toggle vinyl effect"
msgstr "Clics pour basculer l'effet vinyle"

msgid "Clicks to toggle lyrics view"
msgstr "Clics pour basculer les paroles"

msgid "Note: thresholds must be different"
msgstr "Note : les seuils doivent être différents"

msgid "Rapidly click the album art this many times to enable or disable the vinyl record style for the current app"
msgstr "Cliquer rapidement sur la pochette ce nombre de fois pour activer ou désactiver le style vinyle pour l'app actuelle"

msgid "Rapidly click the album art this many times to open or close the synced lyrics panel"
msgstr "Cliquer rapidement sur la pochette ce nombre de fois pour ouvrir ou fermer le panneau de paroles synchronisées"

msgid "If both thresholds are set to the same number the lyrics action takes priority. Use distinct values (e.g. 2 for vinyl, 3 for lyrics) to trigger both independently."
msgstr "Si les deux seuils sont identiques, l'action paroles a la priorité. Utiliser des valeurs distinctes (ex. 2 pour vinyle, 3 pour paroles) pour les déclencher indépendamment."
