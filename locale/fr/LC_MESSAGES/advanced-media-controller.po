msgstr "Paramètres du panneau"

msgid "Configure the position and appearance in the top panel"
msgstr "Configurer la position et l’apparence dans le panneau supérieur"

msgid "Display Settings"
msgstr "Paramètres d’affichage"

msgid "Configure what appears in the panel"
msgstr "Configurer ce qui apparaît dans le panneau"

msgid "Display track information in the panel"
msgstr "Afficher les informations de la piste dans le panneau"

msgid "Include artist name with track title"
msgstr "Inclure le nom de l’artiste avec le titre de la piste"

