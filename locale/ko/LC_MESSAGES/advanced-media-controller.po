#: ui/generalPage.js
msgid "Panel Label Width"
msgstr "패널 레이블 너비"

#: ui/generalPage.js
msgid "Visible pixel width of the track label in the top bar (60 – 400 px)"
msgstr "상단 표시줄의 트랙 레이블 표시 픽셀 너비 (60 – 400 px)"

#: ui/popupPage.js
msgid "Popup Size"
msgstr "팝업 크기"

#: ui/popupPage.js
msgid "Width of the popup media player panel (height scales with album art)"
msgstr "팝업 미디어 플레이어 패널 너비 (높이는 앨범 아트에 맞게 조정)"

#: ui/popupPage.js
msgid "Popup Width"
msgstr "팝업 너비"

#: ui/popupPage.js
msgid "Width in pixels — album art, labels and lyrics panel all scale with this value (280 – 600 px)"
msgstr "픽셀 단위 너비 — 앨범 아트, 레이블 및 가사 패널이 이 값에 맞게 조정됩니다 (280 – 600 px)"

#: ui/popupPage.js
msgid "Tonearm Angles"
msgstr "토닐 암 각도"

#: ui/popupPage.js
msgid "Control how far the animated tonearm swings when playing or at rest"
msgstr "재생 중 또는 휴지 상태에서 애니메이션 토닐 암이 얼마나 흔들리는지 제어"

#: ui/popupPage.js
msgid "Parked (resting) angle"
msgstr "주차 (휴지) 각도"

#: ui/popupPage.js
msgid "Degrees from vertical when music is paused or stopped. Higher moves the arm further from the disc (10 – 60°)"
msgstr "음악이 일시 정지되거나 정지된 경우 수직에서의 각도. 높을수록 암이 디스크에서 멀어집니다 (10 – 60°)"

#: ui/popupPage.js
msgid "Playing angle"
msgstr "재생 각도"

#: ui/popupPage.js
msgid "Degrees from vertical when the stylus rests on the groove. Lower brings the arm closer to the disc centre (0 – 30°)"
msgstr "스타일러스가 홈에 놓였을 때 수직에서의 각도. 낮을수록 암이 디스크 중앙에 가까워집니다 (0 – 30°)"

#: ui/popupPage.js
msgid "Tip: parked angle must be greater than playing angle"
msgstr "팁: 주차 각도는 재생 각도보다 커야 합니다"

#: ui/popupPage.js
msgid "E.g. parked = 25°, playing = 8°. If they are equal or reversed the arm will animate incorrectly."
msgstr "예: 주차 = 25°, 재생 = 8°. 같거나 반대로 설정하면 암이 잘못 애니메이션됩니다."

#: ui/aboutPage.js
msgid "Report a Bug"
msgstr "버그 신고"

#: ui/aboutPage.js
msgid "Request a Feature"
msgstr "기능 요청"

#: ui/aboutPage.js
msgid "Star on GitHub"
msgstr "GitHub에서 별 주기"

