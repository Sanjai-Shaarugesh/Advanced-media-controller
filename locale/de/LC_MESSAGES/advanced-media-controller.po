msgstr "GPL-3.0-Lizenz – Freie und quelloffene Software"

msgid "Media Data Sources"
msgstr "Mediendatenquellen"

msgid "MPRIS D-Bus interface - Standard media player remote interfacing"
msgstr "MPRIS D-Bus-Schnittstelle – Standard-Fernbedienung für Mediaplayer"

msgid "Key Features"
msgstr "Hauptfunktionen"

msgid "• Multi-instance browser support\n"
"• Per-app rotating vinyl record album art\n"
"• Animated tonearm\n"
"• Smooth animations\n"
"• Double-click to toggle vinyl per app\n"
"• All seen apps remembered — re-enable any time"
msgstr "• Multi-Instanz-Browser-Unterstützung\n"
"• App-spezifisches rotierendes Vinyl-Albumcover\n"
"• Animierter Tonarm\n"
"• Sanfte Animationen\n"
"• Doppelklick zum Umschalten des Vinyls je App\n"
"• Alle gesehenen Apps werden erinnert — jederzeit wieder aktivieren"

msgid "Copy to Clipboard"
msgstr "In Zwischenablage kopieren"

msgid "Unable to copy automatically. Select the address below and press Ctrl+C:"
msgstr "Automatisches Kopieren nicht möglich. Wählen Sie die Adresse unten und drücken Sie Strg+C:"

msgid "Close"
msgstr "Schließen"

msgid "Media Controls"
msgstr "Mediensteuerung"

msgid "Panel Settings"
msgstr "Panel-Einstellungen"

msgid "Configure the position and appearance in the top panel"
msgstr "Position und Erscheinungsbild im oberen Panel konfigurieren"

msgid "Display Settings"
msgstr "Anzeigeeinstellungen"

msgid "Configure what appears in the panel"
msgstr "Konfigurieren, was im Panel angezeigt wird"

msgid "Display track information in the panel"
msgstr "Titelinformationen im Panel anzeigen"

msgid "Include artist name with track title"
msgstr "Künstlername beim Titel einschließen"

msgid "Maximum Title Length"
msgstr "Maximale Titellänge"

msgid "Characters to display before scrolling starts"
msgstr "Zeichen, die angezeigt werden, bevor das Scrollen beginnt"

