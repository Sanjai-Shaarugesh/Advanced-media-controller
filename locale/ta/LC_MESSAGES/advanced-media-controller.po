#: prefs.js:91 prefs.js:2354 prefs.js:2387
msgid "Advanced Media Controller"
msgstr "மேம்பட்ட மீடியா கட்டுப்படுத்தி"

#: prefs.js:97
msgid "General"
msgstr "பொது"

#: prefs.js:103
msgid "Panel Placement"
msgstr "பேனல் அமைவு"

#: prefs.js:104
msgid "Where the indicator sits in the top bar"
msgstr "மேல் பட்டியில் காட்டி எங்கு இருக்கும்"

#: prefs.js:108
msgid "Panel Position"
msgstr "பேனல் நிலை"

#: prefs.js:110
msgid "Left"
msgstr "இடது"

#: prefs.js:110
msgid "Center"
msgstr "மையம்"

#: prefs.js:110
msgid "Right"
msgstr "வலது"

#: prefs.js:125
msgid "Panel Index"
msgstr "பேனல் குறியீடு"

#: prefs.js:126
msgid "Position within the panel area (-1 = automatic)"
msgstr "பேனல் பகுதியில் நிலை (-1 = தானியங்கி)"

#: prefs.js:144
msgid "Panel Label"
msgstr "பேனல் லேபிள்"

#: prefs.js:145
msgid "Track name shown in the top bar"
msgstr "மேல் பட்டியில் காட்டப்படும் பாடல் பெயர்"

#: prefs.js:150
msgid "Show Track Name"
msgstr "பாடல் பெயரை காட்டு"

#: prefs.js:151
msgid "Display the current track title in the panel"
msgstr "பேனலில் தற்போதைய பாடல் தலைப்பை காட்டு"

#: prefs.js:162
msgid "Show Artist Name"
msgstr "கலைஞர் பெயரை காட்டு"

#: prefs.js:163
msgid "Append the artist name to the track title"
msgstr "பாடல் தலைப்பில் கலைஞர் பெயரை இணை"

#: prefs.js:174
msgid "Title / Artist Separator"
msgstr "தலைப்பு / கலைஞர் பிரிப்பான்"

#: prefs.js:184
msgid "Panel Scrolling"
msgstr "பேனல் உருட்டல்"

#: prefs.js:185
msgid "Marquee scroll of the track label in the top bar"
msgstr "மேல் பட்டியில் பாடல் லேபிளின் மார்க்கி உருட்டல்"

#: prefs.js:190
msgid "Enable Panel Label Scrolling"
msgstr "பேனல் லேபிள் உருட்டலை இயக்கு"

#: prefs.js:192
msgid ""
"Scroll the track/artist text one full loop then pause before repeating. When "
"off, the text is truncated with an ellipsis."
msgstr ""
"பாடல்/கலைஞர் உரையை ஒரு முழு சுற்று உருட்டி பிறகு மீண்டும் செய்வதற்கு முன் "
"இடைநிறுத்தவும். அணைக்கப்பட்டால், உரை மூன்று புள்ளிகளால் வெட்டப்படும்."

#: prefs.js:205
msgid "Panel Scroll Speed"
msgstr "பேனல் உருட்டல் வேகம்"

#: prefs.js:206 prefs.js:314 prefs.js:354
msgid "1 = slowest, 10 = fastest"
msgstr "1 = மிகவும் மெதுவாக, 10 = மிகவும் வேகமாக"

#: prefs.js:224
msgid "System Integration"
msgstr "கணினி ஒருங்கிணைப்பு"

#: prefs.js:226
msgid "Controls how this extension interacts with other parts of GNOME Shell."
msgstr "இந்த நீட்டிப்பு GNOME Shell இன் மற்ற பகுதிகளுடன் எவ்வாறு தொடர்பு கொள்கிறது என்பதை கட்டுப்படுத்துகிறது."

#: prefs.js:237
msgid "Hide Default GNOME Media Player"
msgstr "இயல்புநிலை GNOME மீடியா பிளேயரை மறை"

#: prefs.js:239
msgid "Remove the built-in media controls from the system date/time menu"
msgstr "கணினி தேதி/நேர மெனுவிலிருந்து உள்ளமைந்த மீடியா கட்டுப்பாடுகளை அகற்று"

#: prefs.js:260
msgid ""
"When ON, the extension hides the stock GNOME media controls that\n"
"normally appear in the calendar / notification panel (the date-time\n"
"menu). This prevents a duplicate 'now playing' widget.\n"
"\n"
"The built-in controls are fully restored the moment you:\n"
"  • Turn this switch off, or\n"
"  • Disable or uninstall this extension."
msgstr ""
"இயக்கப்படும்போது, நீட்டிப்பு இயல்பாக காலண்டர் / அறிவிப்பு பேனலில்\n"
"(தேதி-நேர மெனு) தோன்றும் இயல்புநிலை GNOME மீடியா கட்டுப்பாடுகளை மறைக்கிறது.\n"
"இது நகல் 'இப்போது இயங்குகிறது' விட்ஜெட்டை தடுக்கிறது.\n"
"\n"
"நீங்கள் பின்வருவனவற்றை செய்யும் தருணத்தில் உள்ளமைந்த கட்டுப்பாடுகள் முழுமையாக மீட்டமைக்கப்படும்:\n"
"  • இந்த சுவிட்சை அணைக்கும்போது, அல்லது\n"
"  • இந்த நீட்டிப்பை முடக்கும் அல்லது நிறுவல் நீக்கும்போது."

#: prefs.js:286
msgid "Popup Player"
msgstr "பாப்அப் பிளேயர்"

#: prefs.js:292
msgid "Title Scrolling"
msgstr "தலைப்பு உருட்டல்"

#: prefs.js:293
msgid "Marquee behaviour for the track title inside the popup"
msgstr "பாப்அப்பில் பாடல் தலைப்பிற்கான மார்க்கி நடத்தை"

#: prefs.js:298
msgid "Enable Title Scrolling"
msgstr "தலைப்பு உருட்டலை இயக்கு"

#: prefs.js:300
msgid ""
"Scroll long track titles from start to end, pause, then repeat. When off, "
"the text is truncated with an ellipsis."
msgstr ""
"நீண்ட பாடல் தலைப்புகளை தொடக்கத்திலிருந்து இறுதிவரை உருட்டி, இடைநிறுத்தி, பிறகு மீண்டும் செய்யவும். "
"அணைக்கப்பட்டால், உரை மூன்று புள்ளிகளால் வெட்டப்படும்."

#: prefs.js:313
msgid "Title Scroll Speed"
msgstr "தலைப்பு உருட்டல் வேகம்"

#: prefs.js:332
msgid "Artist Scrolling"
msgstr "கலைஞர் உருட்டல்"

#: prefs.js:333
msgid "Marquee behaviour for the artist name inside the popup"
msgstr "பாப்அப்பில் கலைஞர் பெயருக்கான மார்க்கி நடத்தை"

#: prefs.js:338
msgid "Enable Artist Scrolling"
msgstr "கலைஞர் உருட்டலை இயக்கு"

#: prefs.js:340
msgid ""
"Scroll long artist names from start to end, pause, then repeat. When off, "
"the text is truncated with an ellipsis."
msgstr ""
"நீண்ட கலைஞர் பெயர்களை தொடக்கத்திலிருந்து இறுதிவரை உருட்டி, இடைநிறுத்தி, பிறகு மீண்டும் செய்யவும். "
"அணைக்கப்பட்டால், உரை மூன்று புள்ளிகளால் வெட்டப்படும்."

#: prefs.js:353
msgid "Artist Scroll Speed"
msgstr "கலைஞர் உருட்டல் வேகம்"

#: prefs.js:373
msgid "Album Art"
msgstr "ஆல்பம் கலை"

#: prefs.js:374
msgid "Vinyl-record rotation animation"
msgstr "வைனல் ரெக்கார்ட் சுழற்சி அனிமேஷன்"

#: prefs.js:379
msgid "Enable Vinyl Record Rotation (Global Default)"
msgstr "வைனல் ரெக்கார்ட் சுழற்சியை இயக்கு (உலகளாவிய இயல்புநிலை)"

#: prefs.js:381
msgid ""
"Global default when no per-app setting exists. Per-app overrides in the "
"‘Vinyl Apps’ section take priority."
msgstr "செயலி-சார் அமைப்பு இல்லாதபோது உலகளாவிய இயல்புநிலை. 'வைனல் ஆப்ஸ்' பிரிவில் உள்ள செயலி-சார் மேலெழுத்துகள் முன்னுரிமை பெறும்."

#: prefs.js:395
msgid "Rotation Speed (seconds per revolution)"
msgstr "சுழற்சி வேகம் (ஒரு சுற்றுக்கு வினாடிகள்)"

#: prefs.js:396
msgid "5 = fastest, 60 = slowest. Recommended: 20–30"
msgstr "5 = மிகவும் வேகமாக, 60 = மிகவும் மெதுவாக. பரிந்துரை: 20–30"

#: prefs.js:414
msgid "Vinyl Effect Details"
msgstr "வைனல் விளைவு விவரங்கள்"

#: prefs.js:415
msgid "How the animated vinyl record works"
msgstr "அனிமேஷன் வைனல் ரெக்கார்ட் எவ்வாறு செயல்படுகிறது"

#: prefs.js:420
msgid ""
"- Album cover appears on a spinning vinyl disc\n"
"- Black vinyl grooves are visible around the edges\n"
"- Animated tonearm moves in and out with playback state\n"
"- Rotation pauses smoothly when music pauses\n"
"  (disc angle is preserved and resumes from the same position)\n"
"- Disc resets to 0° only on a genuine Stop\n"
"- Double-click album art to toggle vinyl for THAT player’s app only\n"
"- Per-app settings override the global default above\n"
"- All seen apps are stored; re-enable any time from Vinyl Apps page"
msgstr ""
"- ஆல்பம் அட்டை சுழலும் வைனல் வட்டில் தோன்றும்\n"
"- கறுப்பு வைனல் வரிசைகள் விளிம்புகளில் தெரியும்\n"
"- அனிமேஷன் டோனாம் இயக்க நிலையுடன் உள்ளே வெளியே நகரும்\n"
"- இசை இடைநிறுத்தப்படும்போது சுழற்சி மென்மையாக நிறுத்தப்படும்\n"
"  (வட்டு கோணம் பாதுகாக்கப்பட்டு அதே நிலையில் மீண்டும் தொடரும்)\n"
"- வட்டு உண்மையான நிறுத்தத்தில் மட்டுமே 0°-க்கு மீட்டமைக்கப்படும்\n"
"- ஆல்பம் கலையை இரட்டை-கிளிக் செய்து அந்த பிளேயரின் செயலிக்கு மட்டும் வைனல் மாற்று\n"
"- செயலி-சார் அமைப்புகள் மேலே உள்ள உலகளாவிய இயல்புநிலையை மேலெழுதும்\n"
"- பார்த்த அனைத்து செயலிகளும் சேமிக்கப்படும்; வைனல் ஆப்ஸ் பக்கத்திலிருந்து எந்த நேரத்திலும் மீண்டும் இயக்கலாம்"

#: prefs.js:445
msgid "Vinyl Apps"
msgstr "வைனல் ஆப்ஸ்"

#: prefs.js:453
msgid "Player Filter"
msgstr "பிளேயர் வடிகட்டி"

#: prefs.js:461
msgid "Lyrics"
msgstr "பாடல் வரிகள்"

#: prefs.js:519 prefs.js:546
msgid "Filter Mode"
msgstr "வடிகட்டி முறை"

#: prefs.js:521
msgid ""
"Choose whether the list below acts as a blacklist (block listed apps) or a "
"whitelist (allow only listed apps). Set to Off to disable filtering entirely."
msgstr ""
"கீழே உள்ள பட்டியல் கருப்புப் பட்டியலாக (பட்டியலிடப்பட்ட செயலிகளை தடை) அல்லது "
"வெள்ளைப் பட்டியலாக (பட்டியலிடப்பட்ட செயலிகளை மட்டும் அனுமதி) செயல்படுமா என தேர்ந்தெடுக்கவும். "
"வடிகட்டலை முற்றிலும் முடக்க அணைவிற்கு அமைக்கவும்."

#: prefs.js:532
msgid "Off"
msgstr "அணை"

#: prefs.js:533
msgid "Blacklist"
msgstr "கருப்புப் பட்டியல்"

#: prefs.js:534
msgid "Whitelist"
msgstr "வெள்ளைப் பட்டியல்"

#: prefs.js:540
msgid "Show all media players — filtering is disabled"
msgstr "அனைத்து மீடியா பிளேயர்களையும் காட்டு — வடிகட்டல் முடக்கப்பட்டுள்ளது"

#: prefs.js:541
msgid "Hide only the players you add to the list below"
msgstr "கீழே உள்ள பட்டியலில் சேர்க்கும் பிளேயர்களை மட்டும் மறை"

#: prefs.js:542
msgid "Show only the players you add to the list below"
msgstr "கீழே உள்ள பட்டியலில் சேர்க்கும் பிளேயர்களை மட்டும் காட்டு"

#: prefs.js:569
msgid "Saved Players"
msgstr "சேமிக்கப்பட்ட பிளேயர்கள்"

#: prefs.js:571
msgid ""
"Each saved player can be individually enabled or disabled in the filter "
"without removing it. The toggle controls whether the filter rule is active "
"for that app. Use the trash button to remove it from the list entirely."
msgstr ""
"சேமிக்கப்பட்ட ஒவ்வொரு பிளேயரையும் அகற்றாமல் வடிகட்டியில் தனித்தனியாக "
"இயக்கலாம் அல்லது முடக்கலாம். டாகிள் அந்த செயலிக்கு வடிகட்டி விதி செயலில் "
"உள்ளதா என்பதை கட்டுப்படுத்துகிறது. பட்டியலிலிருந்து முழுவதுமாக அகற்ற குப்பை பொத்தானை பயன்படுத்தவும்."

#: prefs.js:597
msgid "No players saved yet"
msgstr "இன்னும் எந்த பிளேயரும் சேமிக்கப்படவில்லை"

#: prefs.js:599
msgid ""
"Detect running players below and click “Add to Filter” to add them here."
msgstr ""
"கீழே இயங்கும் பிளேயர்களை கண்டறிந்து இங்கே சேர்க்க \"வடிகட்டியில் சேர்\" என்பதை கிளிக் செய்யவும்."

#: prefs.js:653
#, javascript-format
msgid "Filter rule active for “%s” — click to disable"
msgstr "\"%s\"-க்கு வடிகட்டி விதி செயலில் உள்ளது — முடக்க கிளிக் செய்யவும்"

#: prefs.js:654
#, javascript-format
msgid "Filter rule disabled for “%s” — click to enable"
msgstr "\"%s\"-க்கு வடிகட்டி விதி முடக்கப்பட்டுள்ளது — இயக்க கிளிக் செய்யவும்"

#: prefs.js:676
#, javascript-format
msgid "Remove “%s” from the filter list"
msgstr "வடிகட்டி பட்டியலிலிருந்து \"%s\" அகற்று"

#: prefs.js:709
msgid "Detected Players"
msgstr "கண்டறியப்பட்ட பிளேயர்கள்"

#: prefs.js:711
msgid ""
"Active MPRIS players found on the session D-Bus. Click “Add to Filter” to "
"save a player to the list above."
msgstr ""
"அமர்வு D-Bus-ல் கண்டறியப்பட்ட செயலில் MPRIS பிளேயர்கள். "
"மேலே உள்ள பட்டியலில் பிளேயரை சேமிக்க \"வடிகட்டியில் சேர்\" என்பதை கிளிக் செய்யவும்."

#: prefs.js:718
msgid "Scan for running players"
