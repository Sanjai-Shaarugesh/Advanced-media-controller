msgstr "Tamanho do pop-up"

#: ui/popupPage.js
msgid "Width of the popup media player panel (height scales with album art)"
msgstr "Largura do painel do player pop-up (a altura escala com a capa)"

#: ui/popupPage.js
msgid "Popup Width"
msgstr "Largura do pop-up"

#: ui/popupPage.js
msgid "Width in pixels — album art, labels and lyrics panel all scale with this value (280 – 600 px)"
msgstr "Largura em pixels — capa, rótulos e painel de letras escalam com este valor (280 – 600 px)"

#: ui/popupPage.js
msgid "Tonearm Angles"
msgstr "Ângulos do braço de leitura"

#: ui/popupPage.js
msgid "Control how far the animated tonearm swings when playing or at rest"
msgstr "Controla o quanto o braço animado oscila ao reproduzir ou em repouso"

#: ui/popupPage.js
msgid "Parked (resting) angle"
msgstr "Ângulo em repouso"

#: ui/popupPage.js
msgid "Degrees from vertical when music is paused or stopped. Higher moves the arm further from the disc (10 – 60°)"
msgstr "Graus da vertical quando a música está pausada ou parada. Maior afasta o braço do disco (10 – 60°)"

#: ui/popupPage.js
msgid "Playing angle"
msgstr "Ângulo de reprodução"

#: ui/popupPage.js
msgid "Degrees from vertical when the stylus rests on the groove. Lower brings the arm closer to the disc centre (0 – 30°)"
msgstr "Graus da vertical quando a agulha repousa no sulco. Menor aproxima o braço do centro do disco (0 – 30°)"

#: ui/popupPage.js
msgid "Tip: parked angle must be greater than playing angle"
msgstr "Dica: o ângulo em repouso deve ser maior que o ângulo de reprodução"

#: ui/popupPage.js
msgid "E.g. parked = 25°, playing = 8°. If they are equal or reversed the arm will animate incorrectly."
msgstr "Ex.: repouso = 25°, reprodução = 8°. Se iguais ou invertidos, o braço animará incorretamente."

