msgstr "Anchura en píxeles visible de la etiqueta de pista en la barra superior (60 – 400 px)"

#: ui/popupPage.js
msgid "Popup Size"
msgstr "Tamaño del emergente"

#: ui/popupPage.js
msgid "Width of the popup media player panel (height scales with album art)"
msgstr "Anchura del panel del reproductor emergente (la altura se escala con la portada)"

#: ui/popupPage.js
msgid "Popup Width"
msgstr "Anchura del emergente"

#: ui/popupPage.js
msgid "Width in pixels — album art, labels and lyrics panel all scale with this value (280 – 600 px)"
msgstr "Anchura en píxeles — portada, etiquetas y panel de letras escalan con este valor (280 – 600 px)"

#: ui/popupPage.js
msgid "Tonearm Angles"
msgstr "Ángulos del brazo de lectura"

#: ui/popupPage.js
msgid "Control how far the animated tonearm swings when playing or at rest"
msgstr "Controla cuánto oscila el brazo de lectura animado al reproducir o en reposo"

#: ui/popupPage.js
msgid "Parked (resting) angle"
msgstr "Ángulo en reposo"

#: ui/popupPage.js
msgid "Degrees from vertical when music is paused or stopped. Higher moves the arm further from the disc (10 – 60°)"
msgstr "Grados desde la vertical cuando la música está en pausa o detenida. Mayor aleja el brazo del disco (10 – 60°)"

#: ui/popupPage.js
msgid "Playing angle"
msgstr "Ángulo de reproducción"

#: ui/popupPage.js
msgid "Degrees from vertical when the stylus rests on the groove. Lower brings the arm closer to the disc centre (0 – 30°)"
msgstr "Grados desde la vertical cuando la aguja descansa en el surco. Menor acerca el brazo al centro del disco (0 – 30°)"

#: ui/popupPage.js
msgid "Tip: parked angle must be greater than playing angle"
msgstr "Consejo: el ángulo en reposo debe ser mayor que el ángulo de reproducción"

#: ui/popupPage.js
msgid "E.g. parked = 25°, playing = 8°. If they are equal or reversed the arm will animate incorrectly."
msgstr "Ej.: reposo = 25°, reproducción = 8°. Si son iguales o invertidos, el brazo animará incorrectamente."

