#: prefs.js:91 prefs.js:2354 prefs.js:2387
msgid "Advanced Media Controller"
msgstr "ตัวควบคุมสื่อขั้นสูง"

#: prefs.js:97
msgid "General"
msgstr "ทั่วไป"

#: prefs.js:103
msgid "Panel Placement"
msgstr "การวางตำแหน่งแผง"

#: prefs.js:104
msgid "Where the indicator sits in the top bar"
msgstr "ตำแหน่งของตัวบ่งชี้บนแถบด้านบน"

#: prefs.js:108
msgid "Panel Position"
msgstr "ตำแหน่งแผง"

#: prefs.js:110
msgid "Left"
msgstr "ซ้าย"

#: prefs.js:110
msgid "Center"
msgstr "กลาง"

#: prefs.js:110
msgid "Right"
msgstr "ขวา"

#: prefs.js:125
msgid "Panel Index"
msgstr "ดัชนีแผง"

#: prefs.js:126
msgid "Position within the panel area (-1 = automatic)"
msgstr "ตำแหน่งในพื้นที่แผง (-1 = อัตโนมัติ)"

#: prefs.js:144
msgid "Panel Label"
msgstr "ป้ายกำกับแผง"

#: prefs.js:145
msgid "Track name shown in the top bar"
msgstr "ชื่อเพลงที่แสดงในแถบด้านบน"

#: prefs.js:150
msgid "Show Track Name"
msgstr "แสดงชื่อเพลง"

#: prefs.js:151
msgid "Display the current track title in the panel"
msgstr "แสดงชื่อเพลงปัจจุบันในแผง"

#: prefs.js:162
msgid "Show Artist Name"
msgstr "แสดงชื่อศิลปิน"

#: prefs.js:163
msgid "Append the artist name to the track title"
msgstr "เพิ่มชื่อศิลปินต่อท้ายชื่อเพลง"

#: prefs.js:174
msgid "Title / Artist Separator"
msgstr "ตัวคั่นชื่อเพลง / ศิลปิน"

#: prefs.js:184
msgid "Panel Scrolling"
msgstr "การเลื่อนแผง"

#: prefs.js:185
msgid "Marquee scroll of the track label in the top bar"
msgstr "การเลื่อนแบบมาร์คีของป้ายกำกับเพลงในแถบด้านบน"

#: prefs.js:190
msgid "Enable Panel Label Scrolling"
msgstr "เปิดใช้งานการเลื่อนป้ายกำกับแผง"

#: prefs.js:192
msgid ""
"Scroll the track/artist text one full loop then pause before repeating. When "
"off, the text is truncated with an ellipsis."
msgstr ""
"เลื่อนข้อความเพลง/ศิลปินหนึ่งรอบแล้วหยุดชั่วคราวก่อนทำซ้ำ "
"เมื่อปิด ข้อความจะถูกตัดด้วยจุดไข่ปลา"

#: prefs.js:205
msgid "Panel Scroll Speed"
msgstr "ความเร็วการเลื่อนแผง"

#: prefs.js:206 prefs.js:314 prefs.js:354
msgid "1 = slowest, 10 = fastest"
msgstr "1 = ช้าที่สุด, 10 = เร็วที่สุด"

#: prefs.js:224
msgid "System Integration"
msgstr "การรวมระบบ"

#: prefs.js:226
msgid "Controls how this extension interacts with other parts of GNOME Shell."
msgstr "ควบคุมวิธีที่ส่วนขยายนี้โต้ตอบกับส่วนอื่นๆ ของ GNOME Shell"

#: prefs.js:237
msgid "Hide Default GNOME Media Player"
msgstr "ซ่อนเครื่องเล่นสื่อเริ่มต้นของ GNOME"

#: prefs.js:239
msgid "Remove the built-in media controls from the system date/time menu"
msgstr "ลบตัวควบคุมสื่อในตัวออกจากเมนูวันที่/เวลาของระบบ"

#: prefs.js:260
msgid ""
"When ON, the extension hides the stock GNOME media controls that\n"
"normally appear in the calendar / notification panel (the date-time\n"
"menu). This prevents a duplicate 'now playing' widget.\n"
"\n"
"The built-in controls are fully restored the moment you:\n"
"  • Turn this switch off, or\n"
"  • Disable or uninstall this extension."
msgstr ""
"เมื่อเปิด ส่วนขยายจะซ่อนตัวควบคุมสื่อ GNOME ที่มักปรากฏใน\n"
"แผงปฏิทิน/การแจ้งเตือน (เมนูวันที่-เวลา) ซึ่งช่วยป้องกันวิดเจ็ต\n"
"'กำลังเล่นอยู่' ที่ซ้ำกัน\n"
"\n"
"ตัวควบคุมในตัวจะได้รับการกู้คืนทันทีเมื่อคุณ:\n"
"  • ปิดสวิตช์นี้ หรือ\n"
"  • ปิดใช้งานหรือถอนการติดตั้งส่วนขยายนี้"

#: prefs.js:286
msgid "Popup Player"
msgstr "เครื่องเล่นป๊อปอัพ"

#: prefs.js:292
msgid "Title Scrolling"
msgstr "การเลื่อนชื่อเพลง"

#: prefs.js:293
msgid "Marquee behaviour for the track title inside the popup"
msgstr "พฤติกรรมมาร์คีสำหรับชื่อเพลงในป๊อปอัพ"

#: prefs.js:298
msgid "Enable Title Scrolling"
msgstr "เปิดใช้งานการเลื่อนชื่อเพลง"

#: prefs.js:300
msgid ""
"Scroll long track titles from start to end, pause, then repeat. When off, "
"the text is truncated with an ellipsis."
msgstr ""
"เลื่อนชื่อเพลงที่ยาวจากต้นจนจบ หยุดชั่วคราว แล้วทำซ้ำ "
"เมื่อปิด ข้อความจะถูกตัดด้วยจุดไข่ปลา"

#: prefs.js:313
msgid "Title Scroll Speed"
msgstr "ความเร็วการเลื่อนชื่อเพลง"

#: prefs.js:332
msgid "Artist Scrolling"
msgstr "การเลื่อนชื่อศิลปิน"

#: prefs.js:333
msgid "Marquee behaviour for the artist name inside the popup"
msgstr "พฤติกรรมมาร์คีสำหรับชื่อศิลปินในป๊อปอัพ"

#: prefs.js:338
msgid "Enable Artist Scrolling"
msgstr "เปิดใช้งานการเลื่อนชื่อศิลปิน"

#: prefs.js:340
msgid ""
"Scroll long artist names from start to end, pause, then repeat. When off, "
"the text is truncated with an ellipsis."
msgstr ""
"เลื่อนชื่อศิลปินที่ยาวจากต้นจนจบ หยุดชั่วคราว แล้วทำซ้ำ "
"เมื่อปิด ข้อความจะถูกตัดด้วยจุดไข่ปลา"

#: prefs.js:353
msgid "Artist Scroll Speed"
msgstr "ความเร็วการเลื่อนชื่อศิลปิน"

#: prefs.js:373
msgid "Album Art"
msgstr "ภาพปกอัลบั้ม"

#: prefs.js:374
msgid "Vinyl-record rotation animation"
msgstr "แอนิเมชันการหมุนแผ่นเสียงไวนิล"

#: prefs.js:379
msgid "Enable Vinyl Record Rotation (Global Default)"
msgstr "เปิดใช้งานการหมุนแผ่นเสียงไวนิล (ค่าเริ่มต้นทั่วโลก)"

#: prefs.js:381
msgid ""
"Global default when no per-app setting exists. Per-app overrides in the "
"‘Vinyl Apps’ section take priority."
msgstr "ค่าเริ่มต้นทั่วโลกเมื่อไม่มีการตั้งค่าเฉพาะแอพ การแทนที่เฉพาะแอพในส่วน 'แอพไวนิล' จะมีความสำคัญกว่า"

#: prefs.js:395
msgid "Rotation Speed (seconds per revolution)"
msgstr "ความเร็วการหมุน (วินาทีต่อรอบ)"

#: prefs.js:396
msgid "5 = fastest, 60 = slowest. Recommended: 20–30"
msgstr "5 = เร็วที่สุด, 60 = ช้าที่สุด แนะนำ: 20–30"

#: prefs.js:414
msgid "Vinyl Effect Details"
msgstr "รายละเอียดเอฟเฟกต์ไวนิล"

#: prefs.js:415
msgid "How the animated vinyl record works"
msgstr "วิธีที่แผ่นเสียงไวนิลแบบแอนิเมชันทำงาน"

#: prefs.js:420
msgid ""
"- Album cover appears on a spinning vinyl disc\n"
"- Black vinyl grooves are visible around the edges\n"
"- Animated tonearm moves in and out with playback state\n"
"- Rotation pauses smoothly when music pauses\n"
"  (disc angle is preserved and resumes from the same position)\n"
"- Disc resets to 0° only on a genuine Stop\n"
"- Double-click album art to toggle vinyl for THAT player’s app only\n"
"- Per-app settings override the global default above\n"
"- All seen apps are stored; re-enable any time from Vinyl Apps page"
msgstr ""
"- ปกอัลบั้มปรากฏบนแผ่นไวนิลที่หมุน\n"
"- ร่องไวนิลสีดำมองเห็นได้รอบขอบ\n"
"- โทนอาร์มแบบแอนิเมชันเคลื่อนเข้าออกตามสถานะการเล่น\n"
"- การหมุนหยุดชั่วคราวอย่างนุ่มนวลเมื่อดนตรีหยุดชั่วคราว\n"
"  (มุมของแผ่นถูกเก็บรักษาและดำเนินต่อจากตำแหน่งเดิม)\n"
"- แผ่นรีเซ็ตเป็น 0° เฉพาะเมื่อหยุดจริงๆ\n"
"- ดับเบิลคลิกภาพปกอัลบั้มเพื่อสลับไวนิลสำหรับแอพของเครื่องเล่นนั้นเท่านั้น\n"
"- การตั้งค่าเฉพาะแอพจะแทนที่ค่าเริ่มต้นทั่วโลกด้านบน\n"
"- แอพทั้งหมดที่เคยเห็นจะถูกบันทึก สามารถเปิดใช้งานใหม่ได้ทุกเวลาจากหน้าแอพไวนิล"

#: prefs.js:445
msgid "Vinyl Apps"
msgstr "แอพไวนิล"

#: prefs.js:453
msgid "Player Filter"
msgstr "ตัวกรองเครื่องเล่น"

#: prefs.js:461
msgid "Lyrics"
msgstr "เนื้อเพลง"

#: prefs.js:519 prefs.js:546
msgid "Filter Mode"
msgstr "โหมดตัวกรอง"

#: prefs.js:521
msgid ""
"Choose whether the list below acts as a blacklist (block listed apps) or a "
"whitelist (allow only listed apps). Set to Off to disable filtering entirely."
msgstr ""
"เลือกว่ารายการด้านล่างทำหน้าที่เป็นบัญชีดำ (บล็อกแอพที่ระบุ) หรือ "
"บัญชีขาว (อนุญาตเฉพาะแอพที่ระบุ) ตั้งเป็นปิดเพื่อปิดใช้งานการกรองทั้งหมด"

#: prefs.js:532
msgid "Off"
msgstr "ปิด"

#: prefs.js:533
msgid "Blacklist"
msgstr "บัญชีดำ"

#: prefs.js:534
msgid "Whitelist"
msgstr "บัญชีขาว"

#: prefs.js:540
msgid "Show all media players — filtering is disabled"
msgstr "แสดงเครื่องเล่นสื่อทั้งหมด — การกรองถูกปิดใช้งาน"

#: prefs.js:541
msgid "Hide only the players you add to the list below"
msgstr "ซ่อนเฉพาะเครื่องเล่นที่คุณเพิ่มในรายการด้านล่าง"

#: prefs.js:542
msgid "Show only the players you add to the list below"
msgstr "แสดงเฉพาะเครื่องเล่นที่คุณเพิ่มในรายการด้านล่าง"

#: prefs.js:569
msgid "Saved Players"
msgstr "เครื่องเล่นที่บันทึก"

#: prefs.js:571
msgid ""
"Each saved player can be individually enabled or disabled in the filter "
"without removing it. The toggle controls whether the filter rule is active "
"for that app. Use the trash button to remove it from the list entirely."
msgstr ""
"เครื่องเล่นที่บันทึกแต่ละรายการสามารถเปิดหรือปิดใช้งานในตัวกรองแยกกันได้โดยไม่ต้องลบออก "
"การสลับควบคุมว่ากฎตัวกรองทำงานอยู่สำหรับแอพนั้นหรือไม่ "
"ใช้ปุ่มถังขยะเพื่อลบออกจากรายการทั้งหมด"

#: prefs.js:597
msgid "No players saved yet"
msgstr "ยังไม่มีเครื่องเล่นที่บันทึกไว้"

#: prefs.js:599
msgid ""
"Detect running players below and click “Add to Filter” to add them here."
msgstr ""
"ตรวจจับเครื่องเล่นที่กำลังทำงานด้านล่างและคลิก \"เพิ่มในตัวกรอง\" เพื่อเพิ่มที่นี่"

#: prefs.js:653
#, javascript-format
msgid "Filter rule active for “%s” — click to disable"
msgstr "กฎตัวกรองทำงานอยู่สำหรับ \"%s\" — คลิกเพื่อปิดใช้งาน"

#: prefs.js:654
#, javascript-format
msgid "Filter rule disabled for “%s” — click to enable"
msgstr "กฎตัวกรองถูกปิดใช้งานสำหรับ \"%s\" — คลิกเพื่อเปิดใช้งาน"

#: prefs.js:676
#, javascript-format
msgid "Remove “%s” from the filter list"
msgstr "ลบ \"%s\" ออกจากรายการตัวกรอง"

#: prefs.js:709
msgid "Detected Players"
msgstr "เครื่องเล่นที่ตรวจพบ"

#: prefs.js:711
msgid ""
"Active MPRIS players found on the session D-Bus. Click “Add to Filter” to "
"save a player to the list above."
msgstr ""
"พบเครื่องเล่น MPRIS ที่ใช้งานอยู่บน session D-Bus "
"คลิก \"เพิ่มในตัวกรอง\" เพื่อบันทึกเครื่องเล่นในรายการด้านบน"

#: prefs.js:718
msgid "Scan for running players"
msgstr "สแกนหาเครื่องเล่นที่กำลังทำงาน"

#: prefs.js:719
msgid "Detects players currently broadcasting on MPRIS"
msgstr "ตรวจจับเครื่องเล่นที่กำลังออกอากาศบน MPRIS"

#: prefs.js:725
msgid "Refresh the detected player list"
msgstr "รีเฟรชรายการเครื่องเล่นที่ตรวจพบ"

#: prefs.js:753
msgid "Could not connect to the session bus"
msgstr "ไม่สามารถเชื่อมต่อกับ session bus ได้"

#: prefs.js:783 prefs.js:1375
msgid "No active players detected"
msgstr "ไม่พบเครื่องเล่นที่ใช้งานอยู่"

#: prefs.js:784 prefs.js:1376
msgid "Open a music app and click Refresh"
msgstr "เปิดแอพเพลงและคลิกรีเฟรช"

#: prefs.js:842 prefs.js:861 prefs.js:871
msgid "Saved ✓"
msgstr "บันทึกแล้ว ✓"

#: prefs.js:843 prefs.js:871
msgid "Add to Filter"
msgstr "เพิ่มในตัวกรอง"

#: prefs.js:849 prefs.js:864
#, javascript-format
msgid "“%s” is already in the filter list"
msgstr "\"%s\" อยู่ในรายการตัวกรองแล้ว"

#: prefs.js:850
#, javascript-format
msgid "Add “%s” to the filter list (enabled by default)"
msgstr "เพิ่ม \"%s\" ในรายการตัวกรอง (เปิดใช้งานตามค่าเริ่มต้น)"

#: prefs.js:899
msgid "Synced Lyrics"
msgstr "เนื้อเพลงซิงค์"

#: prefs.js:901
msgid "Time-synced lyrics fetched from lrclib.net — free, no account needed"
msgstr "เนื้อเพลงซิงค์เวลาจาก lrclib.net — ฟรี ไม่ต้องมีบัญชี"

#: prefs.js:907
msgid "Enable Synced Lyrics"
msgstr "เปิดใช้งานเนื้อเพลงซิงค์"

#: prefs.js:909
msgid ""
"Fetch and display scrolling lyrics that follow the current playback position"
msgstr "ดึงและแสดงเนื้อเพลงแบบเลื่อนที่ติดตามตำแหน่งการเล่นปัจจุบัน"

#: prefs.js:926
msgid "How to Use Lyrics"
msgstr "วิธีใช้เนื้อเพลง"

#: prefs.js:928
msgid ""
"Lyrics are tied to each player tab independently — Spotify and Firefox each "
"remember their own setting"
msgstr ""
"เนื้อเพลงเชื่อมโยงกับแต่ละแท็บเครื่องเล่นอย่างอิสระ — "
"Spotify และ Firefox แต่ละอันจะจำการตั้งค่าของตัวเอง"

#: prefs.js:936
msgid "Start playing a song"
msgstr "เริ่มเล่นเพลง"

#: prefs.js:938
msgid ""
"Open any media player or browser tab (Spotify, YouTube Music, VLC, "
"Rhythmbox…) and play a track so it appears in the panel."
msgstr ""
"เปิดเครื่องเล่นสื่อหรือแท็บเบราว์เซอร์ใดก็ได้ (Spotify, YouTube Music, VLC, "
"Rhythmbox…) และเล่นเพลงเพื่อให้ปรากฏในแผง"

#: prefs.js:943
msgid "Open the popup player"
msgstr "เปิดเครื่องเล่นป๊อปอัพ"

#: prefs.js:945
msgid ""
"Click the media controller icon in the top panel to open the popup. You’ll "
"see the album art, track title, and playback controls."
msgstr ""
"คลิกไอคอนตัวควบคุมสื่อในแผงด้านบนเพื่อเปิดป๊อปอัพ "
"คุณจะเห็นภาพปกอัลบั้ม ชื่อเพลง และตัวควบคุมการเล่น"

#: prefs.js:950
msgid "Triple-click the album art to show lyrics"
msgstr "คลิกภาพปกอัลบั้มสามครั้งเพื่อแสดงเนื้อเพลง"

#: prefs.js:952
msgid ""
"Click the album art three times in quick succession. The cover image will be "
"replaced by the lyrics panel, which scrolls automatically in time with the "
"music."
msgstr ""
"คลิกภาพปกอัลบั้มสามครั้งอย่างรวดเร็ว ภาพปกจะถูกแทนที่ด้วยแผงเนื้อเพลง "
"ซึ่งเลื่อนอัตโนมัติตามจังหวะดนตรี"

#: prefs.js:957
msgid "Single-click the lyrics panel to go back"
msgstr "คลิกแผงเนื้อเพลงหนึ่งครั้งเพื่อกลับ"

#: prefs.js:959
msgid ""
"Tap anywhere on the lyrics panel once to dismiss it and return to the album "
"art — vinyl or normal cover, whichever that app uses."
msgstr ""
"แตะที่ใดก็ได้บนแผงเนื้อเพลงหนึ่งครั้งเพื่อปิดและกลับไปยังภาพปกอัลบั้ม "
"— ไวนิลหรือปกปกติ แล้วแต่ว่าแอพนั้นใช้อะไร"

#: prefs.js:964
msgid "Triple-click again to re-open"
msgstr "คลิกสามครั้งอีกครั้งเพื่อเปิดใหม่"

#: prefs.js:966
msgid ""
"You can toggle the lyrics panel as many times as you like. Each player tab "
"remembers independently whether lyrics are open."
msgstr ""
"คุณสามารถสลับแผงเนื้อเพลงได้กี่ครั้งก็ได้ตามต้องการ "
"แต่ละแท็บเครื่องเล่นจะจำอย่างอิสระว่าเนื้อเพลงเปิดอยู่หรือไม่"

#: prefs.js:986
msgid "Lyrics Behaviour"
msgstr "พฤติกรรมเนื้อเพลง"

#: prefs.js:987
msgid "What happens behind the scenes"
msgstr "สิ่งที่เกิดขึ้นเบื้องหลัง"

#: prefs.js:992
msgid "Lyrics details & edge cases"
msgstr "รายละเอียดเนื้อเพลงและกรณีขอบเขต"

#: prefs.js:993
msgid "What to expect when the lyrics panel is open"
msgstr "สิ่งที่คาดหวังเมื่อแผงเนื้อเพลงเปิดอยู่"

#: prefs.js:999
msgid ""
"Source\n"
"  • Lyrics are fetched from lrclib.net — a free, open public database\n"
"  • No account or API key is required; the request is made silently in the "
"background\n"
"\n"
"Display\n"
"  • The active lyric line is shown larger and centred in the panel\n"
"  • The line above and below are shown at medium size; all others fade out\n"
"  • The panel scrolls smoothly so the active line is always in view\n"
"\n"
"Track changes\n"
"  • When a new song starts while the lyrics panel is open, the view clears\n"
"    and new lyrics are fetched automatically\n"
"  • If no lyrics are found, a “No lyrics found” message is shown\n"
"\n"
"Multiple players\n"
"  • Each player tab (Spotify, YouTube, VLC…) has its own independent\n"
"    lyrics toggle — opening lyrics for one player does not affect any other\n"
"  • Switching tabs restores the correct view (lyrics or album art) for\n"
"    the player you switch to\n"
"\n"
"Seeking\n"
"  • When you seek forward or backward, the highlighted line jumps\n"
"    instantly to the correct position"
msgstr ""
"แหล่งที่มา\n"
"  • เนื้อเพลงถูกดึงมาจาก lrclib.net — ฐานข้อมูลสาธารณะที่เปิดและฟรี\n"
"  • ไม่ต้องใช้บัญชีหรือ API key คำขอจะดำเนินการในเบื้องหลังอย่างเงียบๆ\n"
"\n"
"การแสดงผล\n"
"  • บรรทัดเนื้อเพลงที่ใช้งานอยู่จะแสดงขนาดใหญ่กว่าและอยู่ตรงกลางในแผง\n"
"  • บรรทัดด้านบนและด้านล่างแสดงในขนาดกลาง ส่วนที่เหลือจะจางหายไป\n"
"  • แผงเลื่อนอย่างนุ่มนวลเพื่อให้บรรทัดที่ใช้งานอยู่มองเห็นได้เสมอ\n"
"\n"
"การเปลี่ยนเพลง\n"
"  • เมื่อเพลงใหม่เริ่มต้นในขณะที่แผงเนื้อเพลงเปิดอยู่ มุมมองจะถูกล้าง\n"
"    และเนื้อเพลงใหม่จะถูกดึงมาโดยอัตโนมัติ\n"
"  • หากไม่พบเนื้อเพลง จะแสดงข้อความ \"ไม่พบเนื้อเพลง\"\n"
"\n"
"หลายเครื่องเล่น\n"
"  • แต่ละแท็บเครื่องเล่น (Spotify, YouTube, VLC…) มีการสลับเนื้อเพลง\n"
"    ที่เป็นอิสระของตัวเอง — การเปิดเนื้อเพลงสำหรับเครื่องเล่นหนึ่งไม่กระทบกับอื่นๆ\n"
"  • การสลับแท็บจะกู้คืนมุมมองที่ถูกต้อง (เนื้อเพลงหรือภาพปกอัลบั้ม)\n"
"    สำหรับเครื่องเล่นที่คุณสลับไป\n"
"\n"
"การค้นหา\n"
"  • เมื่อคุณค้นหาไปข้างหน้าหรือข้างหลัง บรรทัดที่ไฮไลต์จะกระโดด\n"
"    ไปยังตำแหน่งที่ถูกต้องทันที"

#: prefs.js:1039
