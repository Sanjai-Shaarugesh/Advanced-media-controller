#: prefs.js:1084
msgid "Data Source"
msgstr "แหล่งข้อมูล"

#: prefs.js:1085
msgid "Where lyrics come from"
msgstr "เนื้อเพลงมาจากไหน"

#: prefs.js:1090
msgid "lrclib.net"
msgstr "lrclib.net"

#: prefs.js:1092
msgid ""
"Free, open-source time-synced lyrics database — no sign-up, no tracking, no "
